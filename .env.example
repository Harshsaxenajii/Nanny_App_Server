# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (get from Atlas → Connect → Drivers)
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_to_a_long_random_string
JWT_REFRESH_SECRET=change_me_to_another_long_random_string
# Token expiry (e.g. "15m", "7d")
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=7d

# ─── AI (Gemini) ──────────────────────────────────────────────────────────────
GEMINI_API_KEY=your_gemini_api_key_here

# ─── Firebase (Push Notifications) ────────────────────────────────────────────
# Paste the full content of service-account.json as a single-line JSON string.
# In bash: export FIREBASE_SERVICE_ACCOUNT=$(cat service-account.json | tr -d '\n')
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"...","private_key_id":"...","private_key":"-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n","client_email":"...","client_id":"...","auth_uri":"...","token_uri":"..."}

# ─── Razorpay (Payments) ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# Set to "true" when using cron-job.org (Render free tier).
# Set to "false" (or remove) on paid Render/Railway where the server never sleeps.
USE_EXTERNAL_CRON=true

# A random secret shared with cron-job.org.
# cron-job.org must send:  Authorization: Bearer <this value>
# Generate one: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate_a_random_secret_here

# Optional: override cron schedules (UTC cron expressions)
# MIDNIGHT_PLAN_CRON=0 18 * * *
# MORNING_TASK_CRON=30 23 * * *
# MONTHLY_SUMMARY_CRON=0 20 1 * *

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed origins
CORS_ORIGINS=https://your-frontend.com,https://your-admin.com
