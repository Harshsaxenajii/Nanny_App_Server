# ─── Server ───────────────────────────────────────────────────────────────────
NODE_ENV=production
PORT=3000

# ─── Database ─────────────────────────────────────────────────────────────────
MONGO_URI=mongodb+srv://<user>:<password>@cluster0.xxxxx.mongodb.net/<dbname>?retryWrites=true&w=majority

# ─── Auth ─────────────────────────────────────────────────────────────────────
JWT_ACCESS_SECRET=change_me_min_32_chars_xxxxxxxxxxxxxxxx
JWT_REFRESH_SECRET=change_me_min_32_chars_yyyyyyyyyyyyyyyy
JWT_ACCESS_EXPIRY=15m
JWT_REFRESH_EXPIRY=30d

# ─── OTP ──────────────────────────────────────────────────────────────────────
OTP_EXPIRY_SECONDS=300
MAX_OTP_ATTEMPTS=5

# ─── SMS — MSG91 ──────────────────────────────────────────────────────────────
MSG91_AUTH_KEY=your_msg91_auth_key
MSG91_TEMPLATE_ID=your_msg91_template_id
MSG91_SENDER_ID=NANNY

# ─── AI ───────────────────────────────────────────────────────────────────────
# Gemini — used by ai.service.ts for plan/task generation
GEMINI_API_KEY=your_gemini_api_key

# Anthropic — used by other AI features in the codebase
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Firebase (Push Notifications) ────────────────────────────────────────────
# Paste the ENTIRE service-account.json as a single-line JSON string.
# Quick way to get it:  node -e "console.log(JSON.stringify(require('./service-account.json')))"
FIREBASE_SERVICE_ACCOUNT={"type":"service_account","project_id":"YOUR_PROJECT","private_key_id":"KEY_ID","private_key":"-----BEGIN PRIVATE KEY-----\nYOUR_KEY\n-----END PRIVATE KEY-----\n","client_email":"firebase-adminsdk@YOUR_PROJECT.iam.gserviceaccount.com","client_id":"CLIENT_ID","auth_uri":"https://accounts.google.com/o/oauth2/auth","token_uri":"https://oauth2.googleapis.com/token"}

# ─── Payments — Razorpay ──────────────────────────────────────────────────────
RAZORPAY_KEY_ID=rzp_live_xxxxxxxxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_key_secret
RAZORPAY_WEBHOOK_SECRET=your_razorpay_webhook_secret

# ─── CORS ─────────────────────────────────────────────────────────────────────
# Comma-separated list of allowed frontend origins (no trailing slash)
CORS_ORIGIN=https://your-frontend.com,https://your-admin-panel.com

# ─── Cron Jobs ────────────────────────────────────────────────────────────────
# On Vercel  → set USE_EXTERNAL_CRON=true  (Vercel's vercel.json crons handle scheduling)
# On Render paid / Railway → set USE_EXTERNAL_CRON=false (node-cron runs internally)
# On Render free  → set USE_EXTERNAL_CRON=true  (use cron-job.org to hit the routes)
USE_EXTERNAL_CRON=true

# Shared secret between your server and whoever calls the cron routes.
# Vercel sends this automatically as "Authorization: Bearer <CRON_SECRET>".
# cron-job.org: add it manually as a request header.
# Generate: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
CRON_SECRET=generate_a_random_64_char_hex_string_here

# Optional: override cron schedules (UTC). Defaults shown below.
# MIDNIGHT_PLAN_CRON=0 18 * * *
# MORNING_TASK_CRON=30 23 * * *
# MONTHLY_SUMMARY_CRON=0 20 1 * *
