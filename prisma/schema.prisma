// ═══════════════════════════════════════════════════════════════
// schema.prisma — verified, redundancy-free
// ═══════════════════════════════════════════════════════════════
//
// Data flow:
//   Parent fills Booking.parentGoalPrompt + RequestedDailyPlan
//   → On booking CONFIRMED, AI reads parentGoalPrompt
//       → creates ChildGoal[] (structured goals)
//       → creates DailyPlan  (master AI strategy)
//   → Every morning AI reads DailyPlan + previous TaskLog[]
//       → creates PlanTask[] for that day
//   → Nanny sees today's PlanTask[] on dashboard
//   → Nanny fills TaskLog per task (completion, mood, notes)
//
// Booking 1:1 relations (bookingId is @unique on the child table):
//   requestedDailyPlan  — parent routine, zero AI
//   dailyPlan           — AI master plan
//
// Booking 1:N relations:
//   childGoals          — AI-parsed goals (one prompt → many goals)
//
// DailyPlan 1:N:
//   tasks (PlanTask[])  — AI generates fresh each morning
//     └─ log (TaskLog?) — nanny fills after completing the task
//
// Removed redundant FKs:
//   ChildGoal.userId  → reach via booking.userId
//   DailyPlan.userId  → reach via booking.userId
//   PlanTask.childId  → reach via plan.childId
//   TaskLog.planId    → reach via task.planId
//   TaskLog.childId   → reach via task.childId (via plan.childId)
//
// ═══════════════════════════════════════════════════════════════

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "mongodb"
  url      = env("MONGO_URI")
}

// ─────────────────────────────────────────────────────────────
// ENUMS
// ─────────────────────────────────────────────────────────────

enum UserRole {
  USER
  NANNY
  ADMIN
  SUPER_ADMIN
}

enum Gender {
  MALE
  FEMALE
  OTHER
}

enum BabyGender {
  BOY
  GIRL
  OTHER
}

enum NannyStatus {
  PENDING_VERIFICATION
  TRAINING_ASSIGNED
  VERIFIED
  REJECTED
  SUSPENDED
}

enum BookingStatus {
  PENDING_PAYMENT
  CONFIRMED
  PENDING_NANNY_CONFIRMATION
  NANNY_ASSIGNED
  IN_PROGRESS
  COMPLETED
  CANCELLED_BY_USER
  CANCELLED_BY_NANNY
  CANCELLED_BY_ADMIN
}

enum ServiceType {
  HOURLY
  PART_TIME
  FULL_TIME
  MONTHLY_SUBSCRIPTION
  ONE_TIME
  OVERNIGHT
  EMERGENCY
  EVENT
  NEWBORN_CARE
  SPECIAL_NEEDS
  MOTHERS_HELPER
  TRAVEL_NANNY
}

enum NotificationType {
  BOOKING_CONFIRMED
  BOOKING_CANCELLED
  BOOKING_COMPLETED
  NANNY_VERIFIED
  NANNY_REJECTED
  PAYMENT_SUCCESS
  PAYMENT_FAILED
  GENERAL
}

enum MessageType {
  TEXT
  IMAGE
  DOCUMENT
}

enum GoalCategory {
  COGNITIVE
  PHYSICAL
  SOCIAL
  EMOTIONAL
  CREATIVE
  ROUTINE
}

enum GoalPriority {
  HIGH
  MEDIUM
  LOW
}

enum PlanDifficulty {
  LOW
  MEDIUM
  HIGH
}

enum TaskCategory {
  COGNITIVE
  PHYSICAL
  SOCIAL
  EMOTIONAL
  CREATIVE
  ROUTINE
}

enum TaskStatus {
  PENDING
  COMPLETED
  SKIPPED
}

enum RequestedPlanStatus {
  ACTIVE
  PAUSED
  COMPLETED
}

enum DisabilityType {
  CEREBRAL_PALSY
  MUSCULAR_DYSTROPHY
  SPINA_BIFIDA
  LIMB_DIFFERENCE
  MOBILITY_IMPAIRMENT
  AUTISM_SPECTRUM_DISORDER
  ATTENTION_DEFICIT_HYPERACTIVITY_DISORDER
  INTELLECTUAL_DISABILITY
  LEARNING_DISABILITY
  DEVELOPMENTAL_DELAY
  VISUAL_IMPAIRMENT
  HEARING_IMPAIRMENT
  DEAF_BLIND
  SPEECH_LANGUAGE_DISORDER
  NONVERBAL
  EPILEPSY
  DOWN_SYNDROME
  FRAGILE_X_SYNDROME
  CHRONIC_ILLNESS
  MULTIPLE_DISABILITIES
  OTHER
}

type TimeSlot {
  startTime DateTime
  endTime   DateTime
  bookingId String?  @db.ObjectId
  isBlock   Boolean  @default(false)
}

type IdDoc {
  idName  String?
  encUrl  String?
  details Json?   @default("[]")
}

// ─────────────────────────────────────────────────────────────
// MODELS — Auth & User
// ─────────────────────────────────────────────────────────────

model User {
  id                           String    @id @default(auto()) @map("_id") @db.ObjectId
  mobile                       String    @unique
  countryCode                  String    @default("+91")
  name                         String    @default("")
  email                        String?
  gender                       Gender?
  dateOfBirth                  DateTime?
  profilePhoto                 String?
  isMobileVerified             Boolean   @default(false)
  role                         UserRole  @default(USER)
  platform                     String?
  lastLoginAt                  DateTime?
  preferredNannyGender         Gender?
  languagesSpoken              String[]
  notificationsSms             Boolean   @default(true)
  notificationsPush            Boolean   @default(true)
  emergencyContactName         String?
  emergencyContactMobile       String?
  emergencyContactRelationship String?
  createdAt                    DateTime  @default(now())
  updatedAt                    DateTime  @updatedAt

  pushTokens       PushToken[]
  otpRecord        OtpRecord?
  refreshTokens    RefreshToken[]
  addresses        Address[]
  childrens        Children[]
  nannyProfile     Nanny?
  bookings         Booking[]         @relation("UserBookings")
  notifications    Notification[]
  auditLogs        AuditLog[]
  chatParticipants ChatParticipant[]
  sentMessages     ChatMessage[]

  @@map("users")
}

model PushToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String?  @db.ObjectId
  token     String   @unique
  platform  String?  @default("android")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User? @relation(fields: [userId], references: [id])

  @@map("push_tokens")
}

model OtpRecord {
  id           String    @id @default(auto()) @map("_id") @db.ObjectId
  userId       String    @unique @db.ObjectId
  mobile       String
  countryCode  String
  otp          String
  attempts     Int       @default(0)
  expiresAt    DateTime
  blockedUntil DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("otp_records")
}

model RefreshToken {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  userId    String   @db.ObjectId
  tokenHash String   @unique
  expiresAt DateTime
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("refresh_tokens")
}

model Address {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  userId       String   @db.ObjectId
  label        String
  addressLine1 String
  addressLine2 String?
  city         String
  state        String
  pincode      String
  country      String   @default("IN")
  isDefault    Boolean  @default(false)
  lat          Float?
  lng          Float?
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("addresses")
}

// ─────────────────────────────────────────────────────────────
// MODELS — Nanny
// ─────────────────────────────────────────────────────────────

model Nanny {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  userId              String        @unique @db.ObjectId
  name                String
  mobile              String
  email               String?
  gender              Gender?
  dateOfBirth         DateTime?
  profilePhoto        String?
  status              NannyStatus   @default(PENDING_VERIFICATION)
  isActive            Boolean       @default(false)
  isAvailable         Boolean       @default(false)
  isTrainingCompleted Boolean       @default(false)
  experience          Int           @default(0)
  bio                 String?
  languages           String[]
  serviceTypes        ServiceType[]
  specializations     String[]
  ageGroupsHandled    String[]
  hourlyRate          Float         @default(0)
  dailyRate           Float?
  serviceRadius       Int?
  workingAreas        String[]
  rating              Float         @default(0)
  totalReviews        Int           @default(0)
  ratingData          Json?         @default("[]")
  totalBookings       Int           @default(0)
  documents           IdDoc[]
  verifiedAt          DateTime?
  verifiedBy          String?
  rejectionReason     String?
  adminNotes          String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt
  reservedSlot        TimeSlot[]
  idDocumentSubmitted Boolean       @default(false)
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings            Booking[]     @relation("NannyBookings")
  taskLogs            TaskLog[]

  @@map("nannies")
}

// ─────────────────────────────────────────────────────────────
// MODELS — Children
// ─────────────────────────────────────────────────────────────

model Children {
  id              String           @id @default(auto()) @map("_id") @db.ObjectId
  userId          String           @db.ObjectId
  name            String
  birthDate       DateTime
  age             Int?
  gender          BabyGender
  disabilities    DisabilityType[] @default([])
  disabilityNotes String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  user       User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  bookings   Booking[]
  childGoals ChildGoal[]
  dailyPlans DailyPlan[]
  planTasks  PlanTask[]
  taskLogs   TaskLog[]

  @@map("childrens")
}

// ─────────────────────────────────────────────────────────────
// MODEL — Booking
//
// FIX: Removed the direct `requestedDailyPlan` relation and
//      `requestedDailyPlanId` FK that was causing the cycle:
//
//      Booking → RequestedDailyPlan → RequestedDayWiseDailyPlan → Booking
//
// The correct path to tasks is:
//   Booking → RequestedDayWiseDailyPlan (1:N, one per date)
//           → RequestedDailyPlan        (1:N, tasks JSON per day)
//
// The correct path to goals is:
//   Booking → ChildCollectionOfGoals (1:N)
//           → ChildGoal              (1:N, one per selected goal)
// ─────────────────────────────────────────────────────────────
model AttendanceRecord {
  id            String           @id @default(auto()) @map("_id") @db.ObjectId
  bookingId     String           @db.ObjectId
  nannyId       String           @db.ObjectId
  userId        String           @db.ObjectId // parent, for quick lookup
  scheduledDate DateTime // midnight UTC of the working day
  clockInAt     DateTime? // when nanny tapped "Start shift"
  clockOutAt    DateTime? // when nanny tapped "End shift"
  status        AttendanceStatus @default(PENDING)
  lateMinutes   Int              @default(0) // minutes after scheduled start
  notes         String? // nanny or admin note
  createdAt     DateTime         @default(now())
  updatedAt     DateTime         @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@unique([bookingId, scheduledDate], name: "bookingId_scheduledDate")
  @@map("attendance_records")
}

enum AttendanceStatus {
  PENDING // scheduled but shift hasn't started yet
  PRESENT // clocked in and out
  ABSENT // never clocked in (set by nightly cron or admin)
  LATE // clocked in > 15 min after scheduledStartTime
  HALF_DAY // clocked out < 50% of expected hours
}

model Booking {
  id                  String        @id @default(auto()) @map("_id") @db.ObjectId
  userId              String        @db.ObjectId
  nannyId             String?       @db.ObjectId
  childrenId          String        @db.ObjectId
  status              BookingStatus @default(PENDING_NANNY_CONFIRMATION)
  serviceType         ServiceType
  scheduledStartTime  DateTime
  scheduledEndTime    DateTime
  actualStartTime     DateTime?
  actualEndTime       DateTime?
  specialInstructions String?

  // Address snapshot
  addressLabel   String?
  addressLine1   String
  addressLine2   String?
  addressCity    String
  addressState   String
  addressPincode String
  addressCountry String  @default("IN")
  addressLat     Float?
  addressLng     Float?

  // Payment
  baseAmount      Float
  gstAmount       Float
  totalAmount     Float
  razorpayOrderId String?
  paymentId       String?
  pricingDetails  Json?

  // Cancellation
  cancellationReason String?
  cancelledBy        String?

  // Misc
  requestedTasks Json?     @default("[]")
  timeline       Json      @default("[]")
  reviewRating   Int?
  reviewComment  String?
  reviewedAt     DateTime?

  // AI input — parent writes free-text goal prompt here
  parentGoalPrompt String?

  // AI status
  aiPlanGenerated   Boolean   @default(false)
  aiPlanGeneratedAt DateTime?
  aiPlanError       String?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ── Scalar relations ──────────────────────────────────────
  user     User     @relation("UserBookings", fields: [userId], references: [id])
  nanny    Nanny?   @relation("NannyBookings", fields: [nannyId], references: [id])
  children Children @relation(fields: [childrenId], references: [id])

  payment  Payment?
  chatRoom ChatRoom?

  // ── Parent-filled: day-wise tasks and goals ───────────────
  // One RequestedDayWiseDailyPlan per calendar date in the booking range.
  // Each day plan owns 1 RequestedDailyPlan with the tasks JSON.
  requestedDayWiseDailyPlan RequestedDayWiseDailyPlan[]
  childGoals                ChildGoal[]

  // ── AI outputs ────────────────────────────────────────────
  dailyPlan         DailyPlan[]
  attendanceRecords AttendanceRecord[]
  workingDays       String[]           @default([])

  @@map("bookings")
}

// ─────────────────────────────────────────────────────────────
// MODEL — RequestedDayWiseDailyPlan
//
// One record per calendar date within the booking.
// e.g. a 5-day booking creates 5 of these, each with its own date.
// Each owns one RequestedDailyPlan that holds the tasks JSON.
// ─────────────────────────────────────────────────────────────

model RequestedDayWiseDailyPlan {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId String   @db.ObjectId
  date      DateTime // The specific calendar date this plan covers
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FIX: onDelete: Cascade so deleting a booking cleans up day plans
  booking            Booking              @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  requestedDailyPlan RequestedDailyPlan[]

  @@map("requested_day_wise_daily_plans")
}

// ─────────────────────────────────────────────────────────────
// MODEL — RequestedDailyPlan
//
// Holds the actual tasks (as JSON) selected by the parent for one day.
// Belongs to one RequestedDayWiseDailyPlan (the date container).
// Nanny reads additionalNotes on the dashboard.
//
// FIX: Removed Booking[] relation and requestedDayWiseDailyPlanId
//      String? (was missing @db.ObjectId — caused silent type mismatch).
//      The only parent is now RequestedDayWiseDailyPlan via proper FK.
// ─────────────────────────────────────────────────────────────

model RequestedDailyPlan {
  id     String              @id @default(auto()) @map("_id") @db.ObjectId
  name   String?
  status RequestedPlanStatus @default(ACTIVE)

  // additionalNotes stores the array of selected tasks from the app:
  // [{ time: "Morning", task: "Breakfast and hygiene" }, ...]
  additionalNotes Json @default("[]")

  // FK to the date container — always required
  requestedDayWiseDailyPlanId String @db.ObjectId

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // FIX: onDelete: Cascade — deleting the day plan deletes its tasks
  requestedDayWiseDailyPlan RequestedDayWiseDailyPlan @relation(fields: [requestedDayWiseDailyPlanId], references: [id], onDelete: Cascade)

  @@map("requested_daily_plans")
}

// ─────────────────────────────────────────────────────────────
// MODELS — Payments & Chat
// ─────────────────────────────────────────────────────────────

model Payment {
  id                String    @id @default(auto()) @map("_id") @db.ObjectId
  bookingId         String    @unique @db.ObjectId
  userId            String    @db.ObjectId
  razorpayOrderId   String?   @unique
  razorpayPaymentId String?
  amount            Float
  currency          String    @default("INR")
  status            String    @default("PENDING")
  refundId          String?
  refundAmount      Float?
  refundReason      String?
  refundedAt        DateTime?
  capturedAt        DateTime?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  booking Booking @relation(fields: [bookingId], references: [id])

  @@map("payments")
}

model ChatRoom {
  id        String   @id @default(auto()) @map("_id") @db.ObjectId
  bookingId String   @unique @db.ObjectId
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  booking      Booking           @relation(fields: [bookingId], references: [id])
  participants ChatParticipant[]
  messages     ChatMessage[]

  @@map("chat_rooms")
}

model ChatParticipant {
  id          String    @id @default(auto()) @map("_id") @db.ObjectId
  roomId      String    @db.ObjectId
  userId      String    @db.ObjectId
  unreadCount Int       @default(0)
  lastReadAt  DateTime?
  createdAt   DateTime  @default(now())

  room ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  user User     @relation(fields: [userId], references: [id])

  @@unique([roomId, userId])
  @@map("chat_participants")
}

model ChatMessage {
  id        String      @id @default(auto()) @map("_id") @db.ObjectId
  roomId    String      @db.ObjectId
  senderId  String      @db.ObjectId
  content   String
  type      MessageType @default(TEXT)
  mediaUrl  String?
  isRead    Boolean     @default(false)
  createdAt DateTime    @default(now())

  room   ChatRoom @relation(fields: [roomId], references: [id], onDelete: Cascade)
  sender User     @relation(fields: [senderId], references: [id])

  @@map("chat_messages")
}

model Notification {
  id        String           @id @default(auto()) @map("_id") @db.ObjectId
  userId    String           @db.ObjectId
  type      NotificationType
  title     String
  body      String
  data      Json?
  isRead    Boolean          @default(false)
  createdAt DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("notifications")
}

model AuditLog {
  id           String   @id @default(auto()) @map("_id") @db.ObjectId
  actorId      String   @db.ObjectId
  actorRole    String
  action       String
  resource     String
  resourceId   String
  previousData Json?
  newData      Json?
  createdAt    DateTime @default(now())

  actor User @relation(fields: [actorId], references: [id])

  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// MODEL — ChildGoal
//
// One record per goal the parent selected at booking time.
// Belongs to one ChildCollectionOfGoals (the booking's goal container).
// Also linked to Children so you can query all goals for a child
// across bookings without joining through the collection.
//
// FIX: childCollectionOfGoalsId changed from String? to String @db.ObjectId
//      — it must always be set when created from the booking flow,
//      and must use @db.ObjectId to match the parent model's id type.
// ─────────────────────────────────────────────────────────────

model ChildGoal {
  id                String       @id @default(auto()) @map("_id") @db.ObjectId
  childId           String       @db.ObjectId
  name              String
  category          GoalCategory
  priority          GoalPriority @default(MEDIUM)
  timelineMonths    Int?
  parentDescription String
  milestones        Json         @default("[]")
  createdAt         DateTime     @default(now())
  updatedAt         DateTime     @updatedAt

  child     Children   @relation(fields: [childId], references: [id], onDelete: Cascade)
  planTasks PlanTask[]
  booking   Booking?   @relation(fields: [bookingId], references: [id])
  bookingId String?    @db.ObjectId

  @@map("child_goals")
}

// ─────────────────────────────────────────────────────────────
// MODEL — DailyPlan (AI-generated, one per booking)
// ─────────────────────────────────────────────────────────────

model DailyPlan {
  id                  String         @id @default(auto()) @map("_id") @db.ObjectId
  bookingId           String         @unique @db.ObjectId
  childId             String         @db.ObjectId
  overallStrategy     String?
  weeklyFocusAreas    Json           @default("[]")
  difficultyLevel     PlanDifficulty @default(MEDIUM)
  totalPlannedMinutes Int            @default(0)
  restWindows         String[]       @default([])
  rawAiResponse       Json
  lastGeneratedDate   DateTime?
  generatedAt         DateTime       @default(now())
  createdAt           DateTime       @default(now())
  updatedAt           DateTime       @updatedAt

  booking Booking    @relation(fields: [bookingId], references: [id], onDelete: Cascade)
  child   Children   @relation(fields: [childId], references: [id], onDelete: Cascade)
  tasks   PlanTask[]

  @@map("daily_plans")
}

// ─────────────────────────────────────────────────────────────
// MODEL — PlanTask (AI-generated daily tasks for nanny)
// ─────────────────────────────────────────────────────────────

model PlanTask {
  id                String         @id @default(auto()) @map("_id") @db.ObjectId
  planId            String         @db.ObjectId
  goalId            String?        @db.ObjectId
  childId           String         @db.ObjectId
  forDate           DateTime
  title             String
  category          TaskCategory
  durationMinutes   Int
  scheduledTime     String
  difficulty        PlanDifficulty @default(MEDIUM)
  description       String
  materials         String[]       @default([])
  successIndicators String[]       @default([])
  nannyNotes        String?
  skipIf            String?
  ifTooEasy         String?
  ifTooHard         String?
  status            TaskStatus     @default(PENDING)
  createdAt         DateTime       @default(now())
  updatedAt         DateTime       @updatedAt

  plan  DailyPlan  @relation(fields: [planId], references: [id], onDelete: Cascade)
  goal  ChildGoal? @relation(fields: [goalId], references: [id])
  child Children   @relation(fields: [childId], references: [id], onDelete: Cascade)
  log   TaskLog?

  @@map("plan_tasks")
}

// ─────────────────────────────────────────────────────────────
// MODEL — TaskLog (nanny fills after each task)
// ─────────────────────────────────────────────────────────────

model TaskLog {
  id               String    @id @default(auto()) @map("_id") @db.ObjectId
  taskId           String    @unique @db.ObjectId
  nannyId          String?   @db.ObjectId
  childrenId       String?   @db.ObjectId
  completionPct    Int       @default(0)
  engagementRating Int?
  moodRating       Int?
  nannyNote        String?
  completedAt      DateTime?
  createdAt        DateTime  @default(now())
  updatedAt        DateTime  @updatedAt

  task     PlanTask  @relation(fields: [taskId], references: [id], onDelete: Cascade)
  nanny    Nanny?    @relation(fields: [nannyId], references: [id])
  children Children? @relation(fields: [childrenId], references: [id])

  @@map("task_logs")
}
